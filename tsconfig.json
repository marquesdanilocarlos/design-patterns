{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ESNext", "DOM"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "removeComments": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": ["./src", "jest"]
}
